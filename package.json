{
  "name": "vault-armor",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install:frontend": "cd frontend && npm install --include=dev",
    "install:backend": "cd backend && npm install --include=dev",
    "install:all": "npm run install:frontend && npm run install:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npx tsc -b",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "cd backend && node dist/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "npm run build:frontend && npm run dev:backend"
  }
}
